# 复制为 .env 后填值。.env 已被 gitignore,密钥绝不进仓库。
# 嵌套配置覆盖用双下划线:PULSEWIRE_<段>__<键>

# --- 数据库密码(compose 默认 pulsewire;生产请改) ---
PULSEWIRE_DATABASE__PASSWORD=pulsewire

# --- LLM:DeepSeek(litellm) ---
PULSEWIRE_DEEPSEEK_API_KEY=

# --- (可选)语义去重云端回滚位:默认 provider=mlx 全本地,用不到这把 key;
#     只有把 config.yaml dedup provider 切回 jina 时才需要 ---
# PULSEWIRE_JINA_API_KEY=

# --- 交付:微信 Server酱 / 飞书 ---
PULSEWIRE_SERVERCHAN_TOKEN=
# 飞书自定义机器人 webhook(deliver.feishu.mode=webhook 时用,只发文字卡)
PULSEWIRE_FEISHU_WEBHOOK=
# 飞书自建应用(deliver.feishu.mode=app 时用,推图到 open_id 私信)
PULSEWIRE_FEISHU_APP_ID=
PULSEWIRE_FEISHU_APP_SECRET=
PULSEWIRE_FEISHU_USER_OPENID=

# --- 可选:GitHub API token(抓 github 源时提速率额度,留空走匿名低额度) ---
PULSEWIRE_GITHUB_TOKEN=

# --- 可选:覆盖单项配置示例 ---
# PULSEWIRE_APP__ENVIRONMENT=prod
# PULSEWIRE_FETCH__CONCURRENCY=64
